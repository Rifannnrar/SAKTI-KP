# Environment variables untuk Docker
# Salin file ini ke .env.docker dan isi nilainya sebelum deploy

APP_NAME=SAKTI
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_KEY=                         # generate: php artisan key:generate --show
FORTIFY_REGISTRATION=false
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Port yang di-expose ke host
APP_PORT=80

# Database
DB_DATABASE=sakti
DB_USERNAME=postgres
DB_PASSWORD=                     # isi password yang kuat!
